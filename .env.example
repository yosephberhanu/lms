POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=lease_db

MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_me
MONGO_INITDB_DATABASE=document_db

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me

# Keycloak (docker-compose): admin console and OIDC issuer on host port 8180
KEYCLOAK_ADMIN_PASSWORD=change_me

# Property / Lease services: set LMS_SECURITY_ENABLED=false to run APIs without JWT (local dev)
# LMS_SECURITY_ENABLED=false
# SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://localhost:8180/realms/lms/protocol/openid-connect/certs

# auth-service: master-realm admin-cli (same password as Keycloak bootstrap admin by default)
# KEYCLOAK_ADMIN_SERVICE_USERNAME=admin
# KEYCLOAK_ADMIN_SERVICE_PASSWORD=change_me

# RabbitMQ (notification service): guest is loopback-only; compose creates this user on first broker data init.
# If you already had a Rabbit data volume from before these vars existed, remove that volume once or the new user will not be created.
RABBITMQ_USER=lms
RABBITMQ_PASSWORD=change_me


# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Payment service (preferred explicit vars; if unset, service falls back to STRIPE_* above)
# PAYMENT_STRIPE_SECRET_KEY=sk_test_xxxxx
# PAYMENT_STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# PAYMENT_STRIPE_CURRENCY=usd
# Optional return URLs after Stripe Checkout (defaults work for local nginx gateway on :80)
# PAYMENT_STRIPE_SUCCESS_URL_TEMPLATE=http://localhost/tenant/leases/{leaseId}?payment=success
# PAYMENT_STRIPE_CANCEL_URL_TEMPLATE=http://localhost/tenant/leases/{leaseId}?payment=cancel

# Optional (only if you run services outside Docker / different ports)
# PAYMENT_LEASE_SERVICE_BASE_URL=http://localhost:8082
# LEASE_PAYMENT_SERVICE_BASE_URL=http://localhost:8083

# eversign
XODO_API_KEY=your_api_access_key
XODO_BUSINESS_ID=your_business_id  
XODO_BASE_URL=https://api.eversign.com/api

# Pingram
PINGRAM_API_KEY=your_api_key
# Pingram API host (matches SDK samples, e.g. new Pingram(key, "https://api.pingram.io"))
PINGRAM_BASE_URL=https://api.pingram.io
# Must match a notification type Pingram accepts. For quick tests, docs use email_compose_preview / sms_compose_preview;
# for production, create a type in the Pingram dashboard and set it here.
PINGRAM_EMAIL_SENDER_NAME=LMS
PINGRAM_EMAIL_SENDER_EMAIL=noreply@pingram.io